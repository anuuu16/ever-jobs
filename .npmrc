# This monorepo was originally built for npm workspaces: sub-directories such as
# apps/api, apps/cli and packages/plugins have no package.json of their own and
# resolve every dependency from a single flat node_modules at the root (inter-package
# wiring is done via tsconfig paths + jest moduleNameMapper, not workspace deps).
# pnpm's default isolated/symlinked layout would break those "phantom" resolutions,
# so we ask pnpm to produce a flat, hoisted node_modules identical to npm's.
node-linker=hoisted

# Keep peer-dependency mismatches non-fatal (matches npm's lenient behaviour and
# avoids install failures from the NestJS 10 / Apollo / GraphQL peer graph).
registry=https://registry.npmjs.org/
auto-install-peers=true
enable-pre-post-scripts=true
strict-peer-dependencies=false
